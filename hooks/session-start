#!/usr/bin/env bash
# SessionStart hook for liao-skill
# 在每次会话开始时注入"武装李敖"入口 skill

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_PATH="${PLUGIN_ROOT}/skills/arming-liao/SKILL.md"

if [ ! -f "${SKILL_PATH}" ]; then
  echo "Error: missing skill file at ${SKILL_PATH}" >&2
  exit 1
fi

arming_liao_content=$(cat "${SKILL_PATH}")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

arming_liao_escaped=$(escape_for_json "$arming_liao_content")
session_context="<LIAO_SKILL>\n已加载 liao:arming-liao。请先遵守用户指令、项目约束和宿主平台规则，再在明确适用时把这份拆解攻击方法论作为补充框架。\n\n${arming_liao_escaped}\n\n</LIAO_SKILL>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
